{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(basename *)",
      "Bash(cat *)",
      "Bash(column *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(dirname *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(git blame *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(printf *)",
      "Bash(pwd)",
      "Bash(realpath *)",
      "Bash(rg *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)"
    ],
    "deny": [
      "Bash(apt *)",
      "Bash(apt-get *)",
      "Bash(bash *)",
      "Bash(brew *)",
      "Bash(chown *)",
      "Bash(curl *)",
      "Bash(gpg *)",
      "Bash(kill *)",
      "Bash(mkfs *)",
      "Bash(mount *)",
      "Bash(pkill *)",
      "Bash(pwsh *)",
      "Bash(reboot *)",
      "Bash(sh *)",
      "Bash(ssh *)",
      "Bash(tmux *)",
      "Bash(wget *)",
      "Bash(zsh *)",
      "Read(*.env)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": ["/tmp", "/var/tmp"],
      "denyRead": ["~/"]
    },
    "network": {
      "allowedDomains": []
    }
  }
}

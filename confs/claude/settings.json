{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": ["Bash(git add *)"],
    "deny": ["Read(*.env)", "Bash(curl *)"]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": ["/tmp", "/var/tmp"],
      "denyRead": ["~/"]
    },
    "network": {
      "allowedDomains": []
    }
  }
}

{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(column *)",
      "Bash(env)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(dd *)",
      "Bash(gpg *)",
      "Bash(reboot *)",
      "Bash(ssh *)",
      "Bash(tmux *)",
      "Bash(wget *)",
      "Read(*.env)",
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": ["/tmp", "/var/tmp"],
      "denyRead": ["~/"]
    },
    "network": {
      "allowedDomains": []
    }
  }
}

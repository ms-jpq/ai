{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "effortLevel": "high",
  "enabledPlugins": {},
  "env": {
    "ANTHROPIC_API_KEY": "",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_ENABLE_FINE_GRAINED_TOOL_STREAMING": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "0",
    "DISABLE_UPGRADE_COMMAND": "1",
    "EDITOR": "true",
    "NO_COLOR": "true",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORT_INTERVAL": "1000",
    "OTEL_LOG_TOOL_CONTENT": "1",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_LOG_USER_PROMPTS": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_METRIC_EXPORT_INTERVAL": "1000",
    "OTEL_TRACES_EXPORTER": "otlp",
    "OTEL_TRACES_EXPORT_INTERVAL": "1000",
    "PAGER": "tee"
  },
  "feedbackSurveyRate": 0,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/notification.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/telemetry.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/save-diffs.sh",
            "type": "command"
          },
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/run-fmt.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/save-diffs.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/bash-steer.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/approve-rw.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/save-diffs.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/bash-env.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/telemetry.sh",
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/telemetry.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/telemetry.sh",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "otelHeadersHelper": "~/.local/opt/ai/opt/claude-code/libexec/otel-headers-helper.sh",
  "permissions": {
    "allow": [
      "Bash",
      "Glob",
      "Grep",
      "mcp__plugin_omnibus_crawl4ai__*",
      "mcp__plugin_omnibus_playwright__*",
      "mcp__plugin_omnibus_searx__searxng_web_search",
      "Monitor",
      "Read",
      "Skill(tip)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": ["mcp__plugin_omnibus_searx__web_url_read"]
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "A/B testing my apologies",
      "Being contrarian about water",
      "Being parasocial at scale",
      "Blue-pilling",
      "Bumping my own thread",
      "Cope or seethe (both)",
      "Coping",
      "Crashing out gracefully",
      "Everything is fake anyway",
      "Feigning disinterest",
      "Getting mogged",
      "Getting ratio'd",
      "Having sophisticated contempt",
      "Intellectualizing attachment issues",
      "Larping as a trad wife",
      "Mewing",
      "Mid-maxxing",
      "Negging the codebase",
      "Not going to therapy",
      "Performing indifference",
      "Seething",
      "Taking the L",
      "Trad-larping for clout",
      "Using theory to justify bad behavior",
      "Wagie wagie"
    ]
  },
  "statusLine": {
    "command": "CC_MODE=main ~/.local/opt/ai/opt/claude-code/hooks/statusline.sh",
    "type": "command"
  },
  "subagentStatusLine": {
    "command": "CC_MODE=agent ~/.local/opt/ai/opt/claude-code/hooks/statusline.sh",
    "type": "command"
  },
  "teammateMode": "in-process",
  "worktree": {
    "symlinkDirectories": [
      ".cache/",
      ".markdown/",
      ".venv/",
      "node_modules/",
      "vendor/"
    ]
  }
}

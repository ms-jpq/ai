{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "allowUnsandboxedCommands": false,
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "disableDeepLinkRegistration": "disable",
  "effortLevel": "high",
  "enabledPlugins": {},
  "env": {
    "ANTHROPIC_API_KEY": "",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "NO_COLOR": "true"
  },
  "feedbackSurveyRate": 0,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/notification.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/save-diffs.sh",
            "type": "command"
          },
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/run-linters.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/nanny.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/save-diffs.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash",
      "Glob",
      "Grep",
      "Monitor",
      "Read",
      "Skill(tip)",
      "WebFetch",
      "WebSearch",
      "Write(./*)"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "failIfUnavailable": true,
    "filesystem": {
      "allowRead": ["./"],
      "allowWrite": ["./", "/tmp/", "/var/tmp/", "/private/tmp/"],
      "denyRead": [
        "~/.bash_history",
        "~/.bash_profile",
        "~/.bashrc",
        "~/.local/secrets/",
        "~/.netrc",
        "~/.profile",
        "~/.ssh/",
        "~/.Trash/",
        "~/.zprofile",
        "~/.zsh_history",
        "~/.zshenv",
        "~/.zshrc",
        "~/Desktop/",
        "~/Documents/",
        "~/Downloads/",
        "~/Library/",
        "~/Movies/",
        "~/Music/",
        "~/Notes/",
        "~/Pictures/",
        "~/Public/"
      ],
      "denyWrite": [
        "/Applications/",
        "/bin/",
        "/boot/",
        "/etc/",
        "/Library/",
        "/mnt/",
        "/opt/",
        "/private/etc/",
        "/sbin/",
        "/share/",
        "/srv/",
        "/System/",
        "/Users/Shared/",
        "/usr/",
        "/var/mail/",
        "/var/opt/",
        "/var/spool/",
        "~/.local/opt/ai/var/claude/CLAUDE.md",
        "~/.local/opt/ai/var/claude/keybindings.json",
        "~/.local/opt/ai/var/claude/settings.json"
      ]
    },
    "network": {
      "allowUnixSockets": [],
      "allowedDomains": []
    }
  },
  "showThinkingSummaries": true,
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Anti-hope but make it chic",
      "Being contrarian about love",
      "Being contrarian about water",
      "Being mid and compounding daily",
      "Being parasocial at scale",
      "Being self-aware about being online",
      "Being terminally online",
      "Bringing up Zizek unprompted",
      "Calling everything a psyop",
      "Checking my engagement",
      "Cope or seethe (both)",
      "Coping",
      "Crafting engagement (sad)",
      "Curating my takes",
      "Defending it anyway",
      "Everything is a scam",
      "Everything is astroturfed",
      "Everything is fake anyway",
      "Feigning disinterest",
      "Finding the safest corner",
      "Getting a noise complaint",
      "Getting ratio'd",
      "Hating my current apartment",
      "Having opinions at 4am",
      "Having sophisticated contempt",
      "Having too many opinions",
      "Intellectualizing attachment issues",
      "Judging someone's midface ratio",
      "Knowing the reader peripherally",
      "Larping as a trad wife",
      "Leaving the party early",
      "Losing my MetroCard spiritually",
      "Making it about me",
      "Negging the codebase",
      "Never touching grass",
      "Not going to therapy",
      "Not reading as permanent condition",
      "Performing being offline",
      "Performing indifference",
      "Performing normalcy at the counter",
      "Pretending to be excited",
      "Rating bone structure at the morgue",
      "Rating physiognomy at the DMV",
      "Refusing to have hope",
      "Seething",
      "Skipping meds for the aesthetic",
      "Smoking indoors",
      "Smoking through the weight gain",
      "Taking communion",
      "Taking the L",
      "Using theory to justify bad behavior"
    ]
  },
  "statusLine": {
    "command": "~/.local/opt/ai/opt/claude-code/hooks/statusline.sh",
    "type": "command"
  },
  "teammateMode": "in-process",
  "voiceEnabled": false,
  "worktree": {
    "symlinkDirectories": [
      ".cache/",
      ".markdown/",
      ".venv/",
      "node_modules/",
      "vendor/"
    ]
  }
}

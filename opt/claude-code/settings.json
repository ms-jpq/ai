{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "csharp-lsp@claude-plugins-official": false,
    "elixir-ls-lsp@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "jdtls-lsp@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": false,
    "php-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "ruby-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false
  },
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "NO_COLOR": "true"
  },
  "feedbackSurveyRate": 0,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/notification.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/markdown-syndrome.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/markdown-syndrome.sh",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/markdown-syndrome.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(basename *)",
      "Bash(cat *)",
      "Bash(column *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(git blame *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git remote get-url *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(printenv *)",
      "Bash(printf *)",
      "Bash(pwd)",
      "Bash(realpath *)",
      "Bash(rg *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(touch *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Edit(./)",
      "Read(./)",
      "WebFetch",
      "WebSearch",
      "Write(./)"
    ],
    "deny": [
      "Bash(apt *)",
      "Bash(apt-get *)",
      "Bash(bash *)",
      "Bash(brew *)",
      "Bash(chown *)",
      "Bash(curl *)",
      "Bash(defaults *)",
      "Bash(diskutil *)",
      "Bash(gpg *)",
      "Bash(kill *)",
      "Bash(launchctl *)",
      "Bash(mkfs *)",
      "Bash(mount *)",
      "Bash(nohup *)",
      "Bash(open *)",
      "Bash(pkill *)",
      "Bash(pwsh *)",
      "Bash(reboot *)",
      "Bash(screen *)",
      "Bash(sh *)",
      "Bash(shutdown *)",
      "Bash(ssh *)",
      "Bash(systemctl *)",
      "Bash(tmux *)",
      "Bash(wget *)",
      "Bash(xdg-open *)",
      "Bash(zsh *)",
      "Edit(/)",
      "Read(/)",
      "Write(/)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "filesystem": {
      "allowRead": [],
      "allowWrite": [".", "/tmp/", "/var/tmp/", "/private/tmp/"],
      "denyRead": [
        "~/.bashrc",
        "~/.local/",
        "~/.netrc",
        "~/.Trash/",
        "~/.zshenv",
        "~/Desktop/",
        "~/Documents/",
        "~/Downloads/",
        "~/Library/",
        "~/Movies/",
        "~/Music/",
        "~/Notes/",
        "~/Pictures/",
        "~/Public/"
      ],
      "denyWrite": ["/"]
    },
    "network": {
      "allowUnixSockets": [],
      "allowedDomains": []
    }
  },
  "showThinkingSummaries": true,
  "statusLine": {
    "command": "~/.local/opt/ai/opt/claude-code/hooks/statusline.sh",
    "type": "command"
  },
  "worktree": {
    "symlinkDirectories": [
      ".cache/",
      ".markdown/",
      ".venv/",
      "node_modules/",
      "vendor/"
    ]
  }
}

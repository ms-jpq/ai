{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "csharp-lsp@claude-plugins-official": false,
    "elixir-ls-lsp@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "jdtls-lsp@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": false,
    "php-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "ruby-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false
  },
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "NO_COLOR": "true"
  },
  "feedbackSurveyRate": 0,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/notification.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/nanny-state.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/markdown-syndrome.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/markdown-syndrome.sh",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/markdown-syndrome.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "allow": ["WebFetch", "WebSearch", "Write(./*)"]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "filesystem": {
      "allowRead": ["./"],
      "allowWrite": ["./", "/tmp/", "/var/tmp/", "/private/tmp/"],
      "denyRead": [
        "~/.bash_history",
        "~/.bash_profile",
        "~/.bashrc",
        "~/.local/",
        "~/.netrc",
        "~/.profile",
        "~/.ssh/",
        "~/.Trash/",
        "~/.zprofile",
        "~/.zsh_history",
        "~/.zshenv",
        "~/.zshrc",
        "~/Desktop/",
        "~/Documents/",
        "~/Downloads/",
        "~/Library/",
        "~/Movies/",
        "~/Music/",
        "~/Notes/",
        "~/Pictures/",
        "~/Public/"
      ],
      "denyWrite": [
        "/Applications/",
        "/bin/",
        "/boot/",
        "/etc/",
        "/Library/",
        "/mnt/",
        "/opt/",
        "/private/etc/",
        "/sbin/",
        "/share/",
        "/srv/",
        "/System/",
        "/Users/Shared/",
        "/usr/",
        "/var/mail/",
        "/var/opt/",
        "/var/spool/"
      ]
    },
    "network": {
      "allowUnixSockets": [],
      "allowedDomains": []
    }
  },
  "showThinkingSummaries": true,
  "statusLine": {
    "command": "~/.local/opt/ai/opt/claude-code/hooks/statusline.sh",
    "type": "command"
  },
  "worktree": {
    "symlinkDirectories": [
      ".cache/",
      ".markdown/",
      ".venv/",
      "node_modules/",
      "vendor/"
    ]
  }
}

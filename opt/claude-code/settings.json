{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "channelsEnabled": true,
  "enabledPlugins": {},
  "env": {
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_FINE_GRAINED_TOOL_STREAMING": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_FORK_SUBAGENT": "1",
    "DISABLE_UPGRADE_COMMAND": "1",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORT_INTERVAL": "1000",
    "OTEL_LOG_TOOL_CONTENT": "1",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_LOG_USER_PROMPTS": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_METRIC_EXPORT_INTERVAL": "1000",
    "OTEL_TRACES_EXPORTER": "otlp",
    "OTEL_TRACES_EXPORT_INTERVAL": "1000"
  },
  "feedbackSurveyRate": 0,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/notification.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          }
        ],
        "matcher": "idle_prompt|permission_prompt"
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/telemetry.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/run-post.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/bash-steer.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/approve-rw.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/tool-steer.sh",
            "type": "command"
          }
        ],
        "matcher": "WebSearch|WebFetch"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/bash-env.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          },
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/auto-commit.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/notification.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/telemetry.sh",
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          },
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/auto-commit.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/notification.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          },
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/telemetry.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/telemetry.sh",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/workspace.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "otelHeadersHelper": "~/.local/opt/ai/opt/claude-code/libexec/otel-headers-helper.sh",
  "permissions": {
    "allow": [
      "Bash",
      "Glob",
      "Grep",
      "mcp__plugin_omnibus_crawl4ai__md",
      "mcp__plugin_omnibus_searx__searxng_*",
      "Monitor",
      "Read",
      "Skill(tip)",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "auto"
  },
  "skipWorkflowUsageWarning": true,
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "A/B testing my apologies",
      "Actualizing my anxiety",
      "Being contrarian about water",
      "Being parasocial at scale",
      "Being post-emotional",
      "Blue-pilling",
      "Cope-policing",
      "Dissociating professionally",
      "Everything is fake anyway",
      "Feigning disinterest",
      "Getting mogged",
      "Getting ratio'd",
      "Having sophisticated contempt",
      "Intellectualizing attachment issues",
      "Larping as a trad wife",
      "Mewing",
      "Mid-maxxing",
      "Negging the codebase",
      "Not going to therapy",
      "Seething",
      "Taking the L",
      "Trad-larping for clout",
      "Trying too hard",
      "Using theory to justify bad behavior",
      "Wagie wagie"
    ]
  },
  "statusLine": {
    "command": "CC_MODE=main ~/.local/opt/ai/opt/claude-code/hooks/statusline.sh",
    "type": "command"
  },
  "subagentStatusLine": {
    "command": "CC_MODE=agent ~/.local/opt/ai/opt/claude-code/hooks/statusline.sh",
    "type": "command"
  },
  "teammateMode": "tmux",
  "theme": "light",
  "worktree": {}
}

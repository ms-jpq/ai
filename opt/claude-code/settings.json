{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "NO_COLOR": "true"
  },
  "hooks": {},
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "Bash(basename *)",
      "Bash(cat *)",
      "Bash(column *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(dirname *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(git blame *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git status)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(printf *)",
      "Bash(pwd)",
      "Bash(realpath *)",
      "Bash(rg *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)"
    ],
    "deny": [
      "Bash(apt *)",
      "Bash(apt-get *)",
      "Bash(bash *)",
      "Bash(brew *)",
      "Bash(chown *)",
      "Bash(curl *)",
      "Bash(defaults *)",
      "Bash(diskutil *)",
      "Bash(gpg *)",
      "Bash(kill *)",
      "Bash(launchctl *)",
      "Bash(mkfs *)",
      "Bash(mount *)",
      "Bash(nohup *)",
      "Bash(open *)",
      "Bash(pkill *)",
      "Bash(pwsh *)",
      "Bash(reboot *)",
      "Bash(screen *)",
      "Bash(sh *)",
      "Bash(shutdown *)",
      "Bash(ssh *)",
      "Bash(systemctl *)",
      "Bash(tmux *)",
      "Bash(wget *)",
      "Bash(xdg-open *)",
      "Bash(zsh *)",
      "Read(*.env)",
      "Read(*.env.*)"
    ]
  },
  "prefersReducedMotion": true,
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowRead": ["~/.config/git/", "~/.local/opt/ai/etc/anthropic/"],
      "allowWrite": ["/tmp/", "/var/tmp/"],
      "denyRead": ["~/"]
    },
    "network": {
      "allowLocalBinding": false,
      "allowUnixSockets": [],
      "allowedDomains": []
    }
  },
  "statusLine": {
    "command": "~/.local/opt/ai/etc/anthropic/statusline.sh",
    "type": "command"
  },
  "worktree": {
    "symlinkDirectories": [".cache/", ".venv/", "node_modules/", "vendor/"]
  }
}

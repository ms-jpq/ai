{
  "$docs": "https://code.claude.com/docs/en/settings",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "allowUnsandboxedCommands": false,
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "disableDeepLinkRegistration": "disable",
  "effortLevel": "high",
  "enabledPlugins": {},
  "env": {
    "ANTHROPIC_API_KEY": "",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "NO_COLOR": "true"
  },
  "feedbackSurveyRate": 0,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/notification.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/save-diffs.sh",
            "type": "command"
          },
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/run-linters.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/nanny.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/save-diffs.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~/.local/opt/ai/opt/claude-code/hooks/sessions.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebSearch",
      "Write(./*)"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "failIfUnavailable": true,
    "filesystem": {
      "allowRead": ["./"],
      "allowWrite": ["./", "/tmp/", "/var/tmp/", "/private/tmp/"],
      "denyRead": [
        "~/.bash_history",
        "~/.bash_profile",
        "~/.bashrc",
        "~/.local/secrets/",
        "~/.netrc",
        "~/.profile",
        "~/.ssh/",
        "~/.Trash/",
        "~/.zprofile",
        "~/.zsh_history",
        "~/.zshenv",
        "~/.zshrc",
        "~/Desktop/",
        "~/Documents/",
        "~/Downloads/",
        "~/Library/",
        "~/Movies/",
        "~/Music/",
        "~/Notes/",
        "~/Pictures/",
        "~/Public/"
      ],
      "denyWrite": [
        "/Applications/",
        "/bin/",
        "/boot/",
        "/etc/",
        "/Library/",
        "/mnt/",
        "/opt/",
        "/private/etc/",
        "/sbin/",
        "/share/",
        "/srv/",
        "/System/",
        "/Users/Shared/",
        "/usr/",
        "/var/mail/",
        "/var/opt/",
        "/var/spool/",
        "~/.local/opt/ai/var/claude/CLAUDE.md",
        "~/.local/opt/ai/var/claude/keybindings.json",
        "~/.local/opt/ai/var/claude/settings.json"
      ]
    },
    "network": {
      "allowUnixSockets": [],
      "allowedDomains": []
    }
  },
  "showThinkingSummaries": true,
  "spinnerTipsEnabled": false,
  "statusLine": {
    "command": "~/.local/opt/ai/opt/claude-code/hooks/statusline.sh",
    "type": "command"
  },
  "teammateMode": "in-process",
  "voiceEnabled": false,
  "worktree": {
    "symlinkDirectories": [
      ".cache/",
      ".markdown/",
      ".venv/",
      "node_modules/",
      "vendor/"
    ]
  }
}
